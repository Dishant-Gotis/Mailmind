# -- Gmail IMAP + SMTP --

# Dedicated Gmail address for MailMind.
GMAIL_ADDRESS=mailmind-assistant@gmail.com

# Gmail App Password (not regular Gmail password).
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Poll interval in seconds. Recommended: 30.
IMAP_POLL_INTERVAL_SECONDS=30

# -- Gemini LLM --

# Gemini API key from Google AI Studio.
GEMINI_API_KEY=AIzaSy...

# Gemini model identifier.
GEMINI_MODEL=gemini-2.0-flash

# Minimum confidence threshold (0.0 to 1.0).
GEMINI_CONFIDENCE_THRESHOLD=0.7

# -- Google Calendar --

# Path to downloaded Google OAuth credentials.
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# Path where OAuth token will be stored.
GOOGLE_CALENDAR_TOKEN_PATH=token.json

# -- Agent behavior --

# Minimum attendee overlap fraction (0.0, 1.0].
ATTENDANCE_THRESHOLD=0.5

# Default meeting duration in minutes.
MEETING_DURATION_MINUTES=60

# -- VIP Scheduling --

# Comma-separated VIP emails. Leave empty if unused.
VIP_EMAIL_LIST=ceo@company.com,cto@company.com
